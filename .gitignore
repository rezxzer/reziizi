# Dependencies
node_modules

# Build output
dist
dist-ssr
build

# Leftover / accidental scaffold (do not commit)
_scaffold_tmp/

# Environment — secrets (never commit; .env.example is the only env file to commit)
.env
.env.*
!.env.example

# Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# TypeScript / Vite cache
*.tsbuildinfo
node_modules/.tmp

# OS
.DS_Store
Thumbs.db

# Editor (optional: remove .vscode if you want to share workspace settings in repo)
.idea
*.swp
*.swo
*~

# Testing / coverage
coverage

# Deployment (if used later)
.vercel
.netlify

# Local Claude worktree artifacts (never commit)
.claude/worktrees/

# Certificates / keys (never commit)
*.pem
*.key
*.p12
