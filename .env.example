# Copy this file to `.env` in the project root (same folder as package.json).
# Do not commit `.env` — it is listed in `.gitignore`.

# Supabase Dashboard → your project → Settings → API
#
# Project URL  → use as VITE_SUPABASE_URL
# anon public  → use as VITE_SUPABASE_ANON_KEY (safe for browser + Vite; RLS must protect data)
#
# Never put the `service_role` secret in any VITE_* variable — it must not ship to the client.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...paste-your-anon-key-from-dashboard
