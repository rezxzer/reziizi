# =============================================================================
# ლოკალური ასლი: დააკოპირე ეს ფაილი → `.env` (იგივე საქაღალდე, სადაც package.json).
# `.env` არ უნდა ავიდეს git-ში.
#
# მნიშვნელობები: Supabase Dashboard → პროექტი → Settings → API
# =============================================================================

# --- კლიენტი (Vite) — ეს ორი სავალდებულოა `npm run dev` / build-ისთვის ---
# URL: Project URL
# Key: anon / public (არა service_role!)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY_PASTE_HERE

# Stripe Checkout ღილაკი Settings-ში — მხოლოდ როცა Edge + Stripe უკვე მიებით (ნაგულისხმევად გამორთული)
# VITE_BILLING_CHECKOUT_ENABLED=true

# --- სერვერი მხოლოდ (არასოდეს VITE_* — ბრაუზერში არ ჩანს) ---
# საჭიროა: Settings → ანგარიშის წაშლა → Vercel-ის `/api/delete-account`
# Key: service_role (იგივე გვერდიდან, სადაც anon key; სხვა გასაღებია!)
# ლოკალურად: მხოლოდ თუ იყენებ `vercel dev` ან სერვერულ ტესტს; უმეტესობას საკმარისია მხოლოდ Vercel Dashboard-ში.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_PASTE_HERE

# --- Password reset (Auth) ---
# No extra env vars. Redirect URL is {browser origin}/reset-password — allowlist in Supabase:
# Dashboard → Authentication → URL Configuration → Redirect URLs.
#
# --- Vercel only: POST /api/delete-account rate limit (optional) ---
# DELETE_ACCOUNT_RATE_LIMIT_MAX=20
# DELETE_ACCOUNT_RATE_LIMIT_WINDOW_MS=3600000
#
# Stripe (optional — when enabling billing at launch): Edge Function secrets in Supabase Dashboard (not VITE_*):
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET — see README.md → „Stripe Premium“.
# create-checkout-session also needs pricing: STRIPE_PRICE_ID (Stripe Dashboard Price id) OR STRIPE_PRICE_UNIT_AMOUNT_CENTS (+ optional STRIPE_PRICE_CURRENCY, STRIPE_PRICE_PRODUCT_NAME).
# Optional: SITE_URL (https://your-production-app) if Origin is missing on Edge calls.
#
# =============================================================================
# Vercel: Environment Variables — იგივე სახელები და მნიშვნელობები რაც ზემოთ,
# გარდა იმისა, რომ VITE_* იკითხება build-ისას, SUPABASE_SERVICE_ROLE_KEY — runtime-ზე API-სთვის.
# შეცვლის შემდეგ: Redeploy.
# =============================================================================
